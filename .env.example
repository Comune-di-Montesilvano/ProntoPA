APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Rome
APP_LOCALE=it
APP_VERSION=dev

# Il nome ente, logo, colori e altri parametri applicativi si configurano
# dall'interfaccia admin (Admin → Impostazioni), non da questo file.

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database (MariaDB container)
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=segnalazioni
DB_USERNAME=segnalazioni
DB_PASSWORD=segnalazioni_secret
DB_ROOT_PASSWORD=root_secret

# Cache & Sessioni (Redis container)
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PORT=6379

# Email — in sviluppo usa Mailpit (http://localhost:8025)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@comune.montesilvano.pe.it"
MAIL_FROM_NAME="${APP_NAME}"

# PEC (solo produzione)
PEC_HOST=mbox.cert.legalmail.it
PEC_PORT=465
PEC_USERNAME=
PEC_PASSWORD=
PEC_ENCRYPTION=ssl

# Nominatim (geocoding — solo infrastruttura, non endpoint modificabile da UI)
OSM_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Le coordinate e zoom default della mappa si configurano in Admin → Impostazioni
# (chiavi: osm_lat, osm_lng, osm_zoom)

# Webhook outbound → sito web Comune (URL e secret configurabili anche da Admin → Impostazioni)
WEBHOOK_CITTADINI_URL=
WEBHOOK_CITTADINI_SECRET=

# Sanctum API (token per sito Comune)
SANCTUM_STATEFUL_DOMAINS=localhost

# Sessione
SESSION_LIFETIME=480
SESSION_COOKIE=segnalazioni_session
